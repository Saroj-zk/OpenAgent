NODE_ENV=production
PORT=3001
BASE_URL=https://your-app-domain.example.com
CORS_ORIGINS=https://your-app-domain.example.com,https://your-admin-domain.example.com

MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-32-plus-character-secret

BASE_SEPOLIA_RPC=https://sepolia.base.org
WSS_URL=wss://your-websocket-provider.example.com
CONTRACT_ADDRESS=0xYourRegistryAddress
SUBSCRIPTIONS_ADDRESS=0xYourSubscriptionsAddress
ADMIN_PRIVATE_KEY=replace-with-your-admin-private-key

AWS_REGION=us-east-1
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_PUBLIC_URL=

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=300
AUTH_RATE_LIMIT_MAX_REQUESTS=20
TRUST_PROXY=false
